<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app_name | default('3ymen') }}{% endblock %}</title>
    {% block head %}{% endblock %}
</head>
<body>
    <header>
        {% block header %}
        <nav>
            <a href="/">{{ app_name | default('3ymen') }}</a>
        </nav>
        {% endblock %}
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer>
        {% block footer %}
        <p>&copy; {{ "now" | date("Y") }} {{ app_name | default('3ymen') }}</p>
        {% endblock %}
    </footer>

    {% block scripts %}{% endblock %}
</body>
</html>
